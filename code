-- LocalScript: ESPAimbot
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local camera = workspace.CurrentCamera
local lp = Players.LocalPlayer

local settings = {
	espEnabled = true,
	aimbotEnabled = false,
	aimbotKey = Enum.KeyCode.Q,
	espColor = Color3.fromRGB(255, 50, 50),
	hiddenColor = Color3.fromRGB(100, 100, 100),
	teamCheck = false,
	smoothness = 0.1,
	lockMode = "crosshair",
	visibleOnly = true,
}

local espObjects = {}
local listeningForKey = false

local function isVisible(player)
	local char = player.Character
	if not char then return false end
	local head = char:FindFirstChild("Head")
	if not head then return false end

	local origin = camera.CFrame.Position
	local direction = head.Position - origin

	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.FilterDescendantsInstances = {lp.Character, char}

	local result = workspace:Raycast(origin, direction, rayParams)
	return result == nil
end

local function removeESP(player)
	if espObjects[player] then
		espObjects[player]:Destroy()
		espObjects[player] = nil
	end
end

local function attachToCharacter(player, character)
	if espObjects[player] then
		espObjects[player]:Destroy()
		espObjects[player] = nil
	end

	local root = character:WaitForChild("HumanoidRootPart", 10)
	local hum = character:WaitForChild("Humanoid", 10)
	if not root or not hum then return end

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "ESP_" .. player.Name
	billboard.AlwaysOnTop = true
	billboard.Size = UDim2.new(0, 120, 0, 50)
	billboard.StudsOffset = Vector3.new(0, 3.5, 0)
	billboard.Adornee = root
	billboard.Parent = root

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Name = "NameLabel"
	nameLabel.Size = UDim2.new(1, 0, 0.55, 0)
	nameLabel.BackgroundTransparency = 1
	nameLabel.TextColor3 = settings.espColor
	nameLabel.TextStrokeTransparency = 0
	nameLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.TextScaled = true
	nameLabel.Text = player.Name
	nameLabel.Parent = billboard

	local healthLabel = Instance.new("TextLabel")
	healthLabel.Name = "HealthLabel"
	healthLabel.Size = UDim2.new(1, 0, 0.45, 0)
	healthLabel.Position = UDim2.new(0, 0, 0.55, 0)
	healthLabel.BackgroundTransparency = 1
	healthLabel.TextColor3 = Color3.fromRGB(50, 255, 50)
	healthLabel.TextStrokeTransparency = 0
	healthLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
	healthLabel.Font = Enum.Font.Gotham
	healthLabel.TextScaled = true
	healthLabel.Text = "HP: " .. math.floor(hum.Health)
	healthLabel.Parent = billboard

	local visLabel = Instance.new("TextLabel")
	visLabel.Name = "VisLabel"
	visLabel.Size = UDim2.new(1, 0, 0, 16)
	visLabel.Position = UDim2.new(0, 0, 1, 2)
	visLabel.BackgroundTransparency = 1
	visLabel.TextStrokeTransparency = 0
	visLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
	visLabel.Font = Enum.Font.Gotham
	visLabel.TextSize = 11
	visLabel.Text = "[VIS]"
	visLabel.TextColor3 = Color3.fromRGB(50, 255, 50)
	visLabel.Parent = billboard

	hum:GetPropertyChangedSignal("Health"):Connect(function()
		healthLabel.Text = "HP: " .. math.floor(hum.Health)
		local ratio = hum.Health / hum.MaxHealth
		healthLabel.TextColor3 = Color3.fromRGB(
			math.floor((1 - ratio) * 255),
			math.floor(ratio * 255),
			50
		)
	end)

	espObjects[player] = billboard
end

local function setupPlayer(player)
	if player == lp then return end
	if player.Character then attachToCharacter(player, player.Character) end
	player.CharacterAdded:Connect(function(character)
		task.wait(0.5)
		attachToCharacter(player, character)
	end)
end

local function setupAll()
	for _, p in Players:GetPlayers() do setupPlayer(p) end
end

Players.PlayerAdded:Connect(setupPlayer)
Players.PlayerRemoving:Connect(removeESP)

local function getTargetByCrosshair()
	local closest, shortestDist = nil, math.huge
	local cx = camera.ViewportSize.X / 2
	local cy = camera.ViewportSize.Y / 2

	for _, p in Players:GetPlayers() do
		if p == lp then continue end
		if settings.teamCheck and p.Team == lp.Team then continue end
		local char = p.Character
		if not char then continue end
		local head = char:FindFirstChild("Head")
		local hum = char:FindFirstChild("Humanoid")
		if not head or not hum or hum.Health <= 0 then continue end
		if settings.visibleOnly and not isVisible(p) then continue end

		local screenPos, onScreen = camera:WorldToViewportPoint(head.Position)
		if not onScreen then continue end

		local dist = Vector2.new(screenPos.X - cx, screenPos.Y - cy).Magnitude
		if dist < shortestDist then
			shortestDist = dist
			closest = head
		end
	end
	return closest
end

local function getTargetByDistance()
	local closest, shortestDist = nil, math.huge
	local myChar = lp.Character
	if not myChar then return end
	local myRoot = myChar:FindFirstChild("HumanoidRootPart")
	if not myRoot then return end

	for _, p in Players:GetPlayers() do
		if p == lp then continue end
		if settings.teamCheck and p.Team == lp.Team then continue end
		local char = p.Character
		if not char then continue end
		local head = char:FindFirstChild("Head")
		local hum = char:FindFirstChild("Humanoid")
		if not head or not hum or hum.Health <= 0 then continue end
		if settings.visibleOnly and not isVisible(p) then continue end

		local dist = (head.Position - myRoot.Position).Magnitude
		if dist < shortestDist then
			shortestDist = dist
			closest = head
		end
	end
	return closest
end

local function getTarget()
	if settings.lockMode == "crosshair" then
		return getTargetByCrosshair()
	else
		return getTargetByDistance()
	end
end

RunService.Heartbeat:Connect(function()
	for player, billboard in pairs(espObjects) do
		if not settings.espEnabled then
			billboard.Enabled = false
			continue
		end
		billboard.Enabled = true

		local visible = isVisible(player)
		local nameLabel = billboard:FindFirstChild("NameLabel")
		local visLabel = billboard:FindFirstChild("VisLabel")

		if nameLabel then
			nameLabel.TextColor3 = visible and settings.espColor or settings.hiddenColor
		end
		if visLabel then
			visLabel.Text = visible and "[VIS]" or "[WALL]"
			visLabel.TextColor3 = visible
				and Color3.fromRGB(50, 255, 50)
				or Color3.fromRGB(255, 80, 80)
		end
	end

	if settings.aimbotEnabled and UserInputService:IsKeyDown(settings.aimbotKey) then
		local target = getTarget()
		if target then
			local targetCF = CFrame.lookAt(camera.CFrame.Position, target.Position)
			camera.CFrame = camera.CFrame:Lerp(targetCF, settings.smoothness)
		end
	end
end)

